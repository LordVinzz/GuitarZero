<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/choose_song_panel"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/menu_overlay_background"
    android:visibility="gone">

    <LinearLayout
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@color/menu_card_background"
        android:elevation="6dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/choose_song_title"
            android:textColor="@color/menu_text_primary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/choose_song_subtitle"
            android:textColor="@color/menu_text_secondary"
            android:textSize="15sp" />

        <Button
            android:id="@+id/button_song_0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/song_button_placeholder" />

        <Button
            android:id="@+id/button_song_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/song_button_placeholder" />

        <Button
            android:id="@+id/button_song_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/song_button_placeholder" />

        <Button
            android:id="@+id/button_back_from_choose_song"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/back_button_label" />

    </LinearLayout>

</FrameLayout>
