<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/in_game_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="gone">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:background="@color/hud_bar_background"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/text_in_game_song"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/menu_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_in_game_level"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/menu_text_secondary"
            android:textSize="14sp" />

    </LinearLayout>

    <ImageButton
        android:id="@+id/button_open_main_menu"
        android:layout_width="128px"
        android:layout_height="128px"
        android:layout_gravity="top|end"
        android:background="@android:color/transparent"
        android:contentDescription="@string/menu_button_label" />

</FrameLayout>
